# ============================================================
# IssueCompass — Environment Variables (Template)
# ============================================================
# Copy this to .env and fill in your values.
# NEVER commit the real .env file to version control.
#
# Generate secrets with: python3 -c "import secrets; print(secrets.token_hex(32))"

# --- GitHub OAuth App ---
# Create at: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/auth/callback/github
OAUTH_GITHUB_CLIENT_ID=your_github_client_id
OAUTH_GITHUB_CLIENT_SECRET=your_github_client_secret

# --- GitHub Personal Access Token ---
# Used by backend for higher API rate limits (60 -> 5000 req/hr)
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo, read:user
GITHUB_TOKEN=your_github_personal_access_token

# --- NextAuth (Frontend) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=generate_a_random_secret_here

# --- Database ---
# Local:          postgresql://user:pass@localhost:5432/issuecompass
# Supabase pooler: postgresql://postgres:PASS@aws-0-{region}.pooler.supabase.com:6543/postgres  (has IPv4)
# Supabase direct: postgresql://postgres:PASS@db.{ref}.supabase.co:5432/postgres  (IPv6-only)
# NOTE: db.{ref}.supabase.co is IPv6-only in many projects. Use the pooler on IPv4-only networks.
# SSL is REQUIRED by Supabase — handled automatically by the app's connect_args.
DATABASE_URL=postgresql://user:pass@localhost:5432/issuecompass

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Backend API URL (used by frontend) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend JWT Secret ---
SECRET_KEY=generate_a_random_secret_here

# --- Groq AI for enhanced skill extraction ---
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
AI_ENABLED=true

# --- Jina AI for embeddings ---
JINA_API_KEY=your_jina_api_key
EMBEDDINGS_ENABLED=true

# --- Upstash Redis (optional, for production) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Metrics ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
METRICS_API_KEY=

# --- CORS ---
ALLOW_ORIGINS=http://localhost:3000

# --- Cookies ---
COOKIE_SECURE=false

# --- App ---
APP_VERSION=1.0.0
