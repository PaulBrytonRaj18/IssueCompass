# ============================================================
# OpenIssue — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- GitHub OAuth App ---
# Create at: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- GitHub Personal Access Token ---
# Used by backend for higher API rate limits (60 -> 5000 req/hr)
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo, read:user
GITHUB_TOKEN=your_github_personal_access_token

# --- NextAuth (Frontend) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_super_secret_random_string_change_this

# --- Database ---
# Local: postgresql://openissue:openissue@localhost:5432/openissue
# Supabase: postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql://openissue:openissue@localhost:5432/openissue

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Backend API URL (used by frontend) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend JWT Secret ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_in_production_use_random_string

# --- Optional: OpenAI for enhanced skill extraction ---
# OPENAI_API_KEY=your_openai_api_key
